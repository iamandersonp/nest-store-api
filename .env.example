# Prettier - File extensions to format
# Comma-separated list of file extensions that should be formatted by Prettier
# Default: html,ts,scss,css,json,js,md
EXTENSIONS=html,ts,scss,css,json,js,md

# Examples for different project types:
# For NestJS/TypeScript only: EXTENSIONS=ts,js,json
# For full-stack with Angular: EXTENSIONS=html,ts,scss,css,json,js
# For React projects: EXTENSIONS=ts,tsx,js,jsx,css,scss,json
# For Vue projects: EXTENSIONS=vue,ts,js,css,scss,json
